{
  "name": "advanced-search-api",
  "version": "0.1.0",
  "description": "Advanced product search API (NestJS + Elasticsearch + Redis, hexagonal architecture).",
  "author": "Luis",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main.js",
    "seed": "ts-node -r tsconfig-paths/register src/seed/seed.command.ts",
    "seed:prod": "node dist/seed/seed.command.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "loadtest": "k6 run --summary-export loadtest/results/battery.json loadtest/battery.js",
    "loadtest:smoke": "k6 run --summary-export loadtest/results/smoke.json loadtest/smoke.js",
    "loadtest:report": "node loadtest/report.mjs --out loadtest/results/REPORT.md"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!main.ts",
      "!**/*.module.ts",
      "!**/dto/**",
      "!**/*.client.factory.ts",
      "!**/*-client.lifecycle.ts",
      "!seed/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "passWithNoTests": true,
    "moduleNameMapper": {
      "^@domain/(.*)$": "<rootDir>/domain/$1",
      "^@application/(.*)$": "<rootDir>/application/$1",
      "^@infrastructure/(.*)$": "<rootDir>/infrastructure/$1",
      "^@presentation/(.*)$": "<rootDir>/presentation/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1"
    }
  }
}
