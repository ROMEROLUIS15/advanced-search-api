# ─────────────────────────────────────────────────────────────
# Advanced Search API — environment configuration
# Copy to `.env` for local development. NEVER commit a real `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
# Comma-separated allowed CORS origins. Empty in production ⇒ same-origin only.
CORS_ORIGINS=

# ── Elasticsearch ──────────────────────────────────────────────
# LOCAL (docker-compose; security disabled, or basic auth):
ELASTICSEARCH_NODE=http://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme
# CLOUD (Elastic Cloud): endpoint + base64 API key instead of basic auth:
# ELASTICSEARCH_NODE=https://<deployment>.es.<region>.cloud.es.io:443
# ELASTICSEARCH_API_KEY=<base64-api-key>
ELASTICSEARCH_INDEX=products
ELASTICSEARCH_TLS_REJECT_UNAUTHORIZED=true

# ── Redis ──────────────────────────────────────────────────────
# LOCAL redis:// — Upstash (cloud) uses rediss:// (TLS)
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Cache TTLs (seconds) ───────────────────────────────────────
CACHE_TTL_SEARCH=300
CACHE_TTL_AUTOCOMPLETE=60

# ── Search: pagination + suggestions ───────────────────────────
SEARCH_DEFAULT_PAGE_SIZE=20
SEARCH_MAX_PAGE_SIZE=100
SEARCH_SUGGEST_MAX_HITS=5
SEARCH_MAX_RESULT_WINDOW=10000

# ── Relevance tuning (function_score) ──────────────────────────
RELEVANCE_POPULARITY_FACTOR=1
RELEVANCE_RECENCY_SCALE=90d
RELEVANCE_RECENCY_DECAY=0.5

# ── Rate limiting (design D14–D19) ─────────────────────────────
# Enforcement switch: the rollback lever, and what the k6 capacity
# run disables so the battery can exceed human traffic on purpose.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
# Per-endpoint budgets per window. Autocomplete is far higher
# because a type-ahead box fires on nearly every keystroke.
RATE_LIMIT_SEARCH=60
RATE_LIMIT_AUTOCOMPLETE=300
RATE_LIMIT_SUGGEST=60
RATE_LIMIT_DEFAULT=120
# Proxy hops to trust when resolving the client address. 0 for a
# direct local connection; 1 behind Render's proxy, where without
# it every client shares one bucket. Never "true": trusting the
# raw X-Forwarded-For lets a client forge its way past the limit.
TRUST_PROXY_HOPS=0
# TRUST_PROXY_HOPS=1
